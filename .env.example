DATABASE_URL=postgresql://root:root@localhost:5432/carsi

# ===========================================
# PROJECT CONFIGURATION
# ===========================================
PROJECT_NAME=my-project
NODE_ENV=development

# ===========================================
# DATABASE (PostgreSQL - Local by default)
# ===========================================
# Local PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgresql://starter_user:local_dev_password@localhost:5433/starter_db

# For production, use your PostgreSQL connection string:
# DATABASE_URL=postgresql://user:password@host:5432/database

# ===========================================
# AUTHENTICATION (JWT)
# ===========================================
# The canonical session secret is JWT_SECRET (defined below under "JWT for student
# sessions"). The code reads process.env.JWT_SECRET only — there is no JWT_SECRET_KEY
# consumer, so it has been removed here to end the naming drift (issue #132).
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_EXPIRE_MINUTES=60

# Webhook signature secret (used for HMAC-SHA256 verification)
WEBHOOK_SECRET=CHANGE_ME

# ===========================================
# CLOUDFLARE TURNSTILE (bot protection on /contact + /submit — issue #118)
# ===========================================
# Both optional: when unset, the widget renders nothing and the server skips
# verification (forms still work). Set both to enable bot protection.
# Dashboard: https://dash.cloudflare.com/?to=/:account/turnstile
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...      # public site key (exposed to browser)
# TURNSTILE_SECRET_KEY=0x4AAAAAAA...                # server secret (siteverify)

# ===========================================
# AI MODELS (All Optional - Ollama used by default)
# ===========================================
# AI Provider: "ollama" (local) or "anthropic" (cloud)
AI_PROVIDER=ollama

# Ollama Configuration (local, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Anthropic (Claude) - Optional cloud provider, not used by any runtime path currently
# ANTHROPIC_API_KEY=sk-ant-xxx

# Google (Gemini) - Optional
# GOOGLE_AI_API_KEY=xxx

# ===========================================
# CARSI — Public & dashboard chat assistant (OpenRouter)
# ===========================================
# Required for /api/margot/chat (Margot, the floating assistant on marketing +
# learner UI). OpenRouter fronts many providers, including free-tier open-weight
# models, over an OpenAI-compatible /chat/completions endpoint.
OPENROUTER_API_KEY=
# Optional override (default: z-ai/glm-5.2 — strong instruction-following so
# Margot honours her strict scope/disclaimer/citation rules, 1M context for her
# knowledge base. Paid: ~$0.69/1M in, ~$2.16/1M out; this endpoint is public, so
# per-IP rate limits cap spend. Zero-cost fallback: google/gemma-4-31b-it:free)
# OPENROUTER_MODEL=z-ai/glm-5.2

# ===========================================
# CARSI — Course thumbnail authoring tool (OpenAI)
# ===========================================
# Only used by scripts/generate-course-thumbnails.ts (authoring tool, never used
# at runtime). Requires the OpenAI org to have completed API verification for
# gpt-image-1.
OPENAI_API_KEY=
# Optional thumbnail-generator overrides (default model gpt-image-1, hard cap 25 images/run)
# OPENAI_IMAGE_MODEL=gpt-image-1
# THUMBNAIL_MAX_GENERATIONS=25
# Display name + tagline (NEXT_PUBLIC_* are exposed to the browser for labels only)
NEXT_PUBLIC_AI_ASSISTANT_NAME=Margot
NEXT_PUBLIC_AI_ASSISTANT_TAGLINE=Online assistant

# ===========================================
# ELEVENLABS (Margot Listen + course voice narration)
# ===========================================
# Runtime: /api/margot/chat/speech — "Listen" on Margot replies (requires API key + voice id).
# Authoring: scripts/generate-course-voiceover.ts → npm run voice:plan / voice:generate.
# Dashboard: https://elevenlabs.io/app/settings/api-keys
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# Legacy typo still supported at runtime: ELEVENLABS_VIOCE_ID=
# Optional overrides (defaults shown).
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# ELEVENLABS_LOCALE=en-AU
# VOICE_MAX_GENERATIONS=50

# ===========================================
# PROFESSIONAL DIRECTORY (GP-449 #298)
# ===========================================
# Leave unset/false until NRPG registry sync (UNI-87) is live — prevents fabricated listings.
# PROFESSIONAL_DIRECTORY_LIVE=false

# ===========================================
# MCP TOOLS
# ===========================================
# Exa (Web Search)
EXA_API_KEY=xxx

# Ref.tools
REF_TOOLS_API_KEY=xxx

# Bright Data Scraping Browser (web scraping for course research — bypasses bot/egress blocks).
# A remote CDP/Selenium browser at brd.superproxy.io that fetches pages from Bright Data's
# network, so /course-research can capture real supplier data (e.g. ccwonline.com.au products +
# SDS PDFs) that this environment's direct egress proxy blocks. Driven by a Playwright script via
# chromium.connectOverCDP(BRIGHTDATA_BROWSER_WSS). Put the real endpoints in .env.local (gitignored).
# Dashboard: https://brightdata.com/cp/zones  (Scraping Browser zone → "endpoints")
# BRIGHTDATA_BROWSER_WSS=wss://brd-customer-XXedit:PASSWORD@brd.superproxy.io:9222
# BRIGHTDATA_BROWSER_WEBDRIVER=https://brd-customer-XXedit:PASSWORD@brd.superproxy.io:9515

# ===========================================
# FRONTEND
# ===========================================
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
# Used in password-reset and enrolment emails (defaults to NEXT_PUBLIC_FRONTEND_URL)
# NEXT_PUBLIC_APP_URL=https://your-production-domain.com.au

# Search crawl submission
# Host verification key for Bing/IndexNow at /indexnow-key.txt and use it in npm run seo:submit-indexnow -- --send.
# Generate the key in Bing Webmaster Tools or at https://www.bing.com/indexnow.
# INDEXNOW_KEY=your-indexnow-key
# INDEXNOW_KEY_LOCATION=https://carsi.com.au/indexnow-key.txt
# INDEXNOW_ENDPOINT=https://api.indexnow.org/indexnow
# GOOGLE_SEARCH_CONSOLE_PROPERTY=https://carsi.com.au/
# GOOGLE_SEARCH_CONSOLE_SITEMAP=https://carsi.com.au/sitemap.xml
# CARSI GA4 Measurement ID. Public, not a secret. Defaults to G-LF86765F5C in production.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-LF86765F5C

# ===========================================
# FUNNEL + ERROR INSTRUMENTATION (WS3 / GP-447 / GitHub #128)
# All three below are optional: every helper no-ops cleanly when its var is
# unset. See docs/runbooks/rana-analytics-keys.md for what to set + how to
# verify each one once configured.
# ===========================================
# GA4 Measurement Protocol API secret — server-side `purchase` event on the
# Stripe webhook. GA4 Admin -> Data Streams -> (web stream) -> Measurement
# Protocol API secrets -> Create.
# GA4_MEASUREMENT_PROTOCOL_API_SECRET=

# PostHog client key (public, write-only project key). PostHog -> Project
# Settings -> Project API Key.
# NEXT_PUBLIC_POSTHOG_KEY=
# Only set if the PostHog project is not US-hosted (default https://us.i.posthog.com).
# NEXT_PUBLIC_POSTHOG_HOST=

# Sentry DSN — server-side error capture on payment/enrolment/CEC-certificate
# routes. Sentry -> Project Settings -> Client Keys (DSN).
# SENTRY_DSN=

# ===========================================
# EMAIL (Mailtrap — registration, forgot password, enrolment, contact)
# ===========================================
# https://mailtrap.io/settings/api-tokens — verify your sending domain in Mailtrap
MAILTRAP_API_KEY=your_mailtrap_api_token
# Must use a verified domain in production, e.g. CARSI Learning <noreply@yourdomain.com.au>
EMAIL_FROM=CARSI Learning <support@carsi.com.au>
# Local dev: log email body to terminal instead of calling Mailtrap (also auto-fallback if send.api.mailtrap.io is unreachable)
# EMAIL_DEV_CONSOLE=true
# Where contact form notifications are sent (defaults to ADMIN_EMAIL or support@carsi.com.au)
# CONTACT_NOTIFY_EMAIL=ops@yourdomain.com.au

# JWT for student sessions (register/login). Also used for password-reset tokens.
JWT_SECRET=change-me-in-production-min-32-chars

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=info

# ===========================================
# DEPLOYMENT (DigitalOcean)
# ===========================================
DO_APP_ID=your-app-id
DO_API_TOKEN=your-do-token
DIGITALOCEAN_API=your-do-token

# ===========================================
# JINA AI (Web Reading / Scraping)
# ===========================================
# Get from: https://jina.ai/
JINA_API_KEY=your-jina-api-key

# CCW product/SDS scraper (scripts/scrape-ccw-products.ts, engine: Jina).
# Catalog/index page the scrape starts from. Runs locally and on Vercel (HTTPS:443).
CCW_SCRAPE_BASE_URL=https://example-ccw-site/products

# ===========================================
# STRIPE (Payments & Billing)
# ===========================================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- WS1-E1 individual annual membership (GP-441) ---
# Feature flag. Absent/false = current coming-soon behaviour (ship dark).
# Set to true ONLY after the annual Stripe Price exists and webhook events are
# configured (see docs/runbooks/rana-stripe-connection.md). Rollback = set false.
SUBSCRIPTIONS_ENABLED=false
# --- GP-199 government-contractor lead magnet ---
# Feature flag. Absent/false = the /resources/government-restoration-panels page
# 404s and its capture route rejects (ship dark). Set true to go live. Rollback =
# set false. Delivery reuses Mailtrap (MAILTRAP_API_KEY) + Turnstile.
GP199_GOV_GUIDE_ENABLED=false
# Optional explicit annual Price id. If unset, the code resolves the active Price
# by lookup_key 'carsi_pro_annual' at runtime. If neither resolves, membership
# checkout fails closed (honest "not yet available"), never a wrong Price.
# STRIPE_PRICE_PRO_ANNUAL=price_xxx
# Teams seat plans (WS1-E2, GP-442) — optional explicit Price ids:
# STRIPE_PRICE_TEAMS_STARTER=price_xxx
# STRIPE_PRICE_TEAMS_GROWTH=price_xxx
# STRIPE_PRICE_TEAMS_FULL_LIBRARY=price_xxx
# Organisation monthly (WS1-E3, GP-443):
# STRIPE_PRICE_ORG_MONTHLY=price_xxx

# ===========================================
# LINEAR (Project Management - MCP Server)
# ===========================================
# Get from: https://linear.app/YOUR-TEAM/settings/api
LINEAR_API_KEY=your-linear-api-key

# ===========================================
# CLOUDINARY (optional — admin course thumbnail uploads)
# ===========================================
# When set, POST /api/admin/upload sends images to Cloudinary and returns an HTTPS URL
# stored in lms_courses.thumbnail_url. If unset, files are written to public/uploads/admin-courses.
# Dashboard: https://console.cloudinary.com/
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# Cloudinary also stores composited demo screencasts (scripts/generate-demo-videos.ts → carsi/demo-videos).

# ===========================================
# DEMO SCREENCASTS (optional — scripts/generate-demo-videos.ts)
# ===========================================
# Authoring tool only (never used at runtime). Drives the seeded demo account with Playwright,
# composites a HeyGen avatar (from the brand-video pipeline) as a PiP overlay via FFmpeg, and
# uploads the result to Cloudinary. Reuses the seeded demo creds, HEYGEN_* and CLOUDINARY_* above.
# DEMO_RECORD_BASE_URL=http://localhost:3000   # app under test for recording
# DEMO_VIDEO_MAX=12                            # hard cap on flows per run
# DEMO_PIP_MARGIN=24                           # avatar PiP inset in px
# FFMPEG_PATH=ffmpeg                           # fallback if @ffmpeg-installer/ffmpeg is absent
# DEMO_STUDENT_EMAIL=student@carsi.com.au      # override the seeded demo account
# DEMO_STUDENT_PASSWORD=student123

# ===========================================
# ADMIN (dashboard at /admin)
# ===========================================
# Server-only (used by /api/admin/login). Quote values if they contain # or spaces.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me
# Optional: comma-separated LMS emails that may use /login then /admin (without /api/admin/login).
# Also allowed: any LMS user with JWT role `admin` (see lms_roles / lms_user_roles).
# ADMIN_PANEL_EMAILS=support@example.com
# Optional: same email shown on the admin login form in the browser (NEXT_PUBLIC_* is bundled for the client).
# NEXT_PUBLIC_ADMIN_EMAIL=you@example.com

# ===========================================
# IICRC CEC auto-submission (course completion)
# ===========================================
# Email IICRC Renewals receives the Certificate of Completion PDF on course completion.
IICRC_CEC_SUBMISSION_EMAIL=renewals@iicrcnet.org
# Set to false to disable auto-send (submissions logged as skipped).
# IICRC_CEC_AUTO_SUBMIT=true

# CCW roadshow Google Calendar sync (consumer Gmail → OAuth refresh token, NOT a service account)
GOOGLE_CALENDAR_ID=phill.mcgurk@gmail.com
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_OAUTH_REFRESH_TOKEN=

# ===========================================
# Additional consumed keys (documented 2026-06-29 — audit config-drift fix)
# Every key below is read somewhere in src/ or app/. Leave blank/commented unless
# the feature is in use. Grouped by purpose.
# ===========================================

# --- Auth / security secrets ---
# ADMIN_JWT_SECRET=              # falls back to JWT_SECRET when unset
# ADMIN_PANEL_EMAILS=            # comma-separated emails allowed into /admin
# NEXT_PUBLIC_ADMIN_EMAIL=
# CRON_SECRET=                   # Bearer token for cron-only endpoints (e.g. CEC submit/process)
# INTERNAL_TOOLS_ENABLED=        # 'true' to expose internal tooling pages
# DATABASE_CA_CERT=              # PEM CA cert for verify-full Postgres SSL (DigitalOcean)

# --- Public site URLs ---
# NEXT_PUBLIC_APP_URL=
# NEXT_PUBLIC_SITE_URL=
# NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_BACKEND_HEALTH_PATH=

# --- Integrations: CRM / Hub / backend ---
# CRM_WEBHOOK_URL=
# CRM_WEBHOOK_SECRET=
# HUB_INTAKE_SECRET=
# BACKEND_API_KEY=
# CONTACT_NOTIFY_EMAIL=
# EMAIL_DEV_CONSOLE=             # 'true' logs reset/email links to console in dev

# --- Cloudinary (media) ---
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- AI providers ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=
# GOOGLE_GENERATIVE_AI_API_KEY=
# AI_ASSISTANT_NAME=
# NEWS_AI_CONCURRENCY=
# NEWS_RELEVANCE_THRESHOLD=

# --- SEO / push / realtime ---
# INDEXNOW_KEY=                  # required for /indexnow-key.txt + seo:submit-indexnow --send
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# NEXT_PUBLIC_YJS_WS_URL=

# --- LMS / content config ---
# LMS_SYSTEM_INSTRUCTOR_ID=
# HOMEPAGE_FEATURED_COURSE_SLUGS=
# IICRC_CEC_AUTO_SUBMIT=

# --- Seed / migration script paths (manual one-off scripts only) ---
# CARSI_COURSES_XLSX_PATH=
# WP_EXPORT_COURSES_PATH=
# WXR_PATH=
