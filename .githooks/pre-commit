#!/usr/bin/env sh
# CARSI pre-commit guard:
#   1. block committing live-looking secrets (issue #122)
#   2. block banned IICRC CEC terminology in staged copy (Linear GP-451)
#   3. type-check with `tsc --noEmit` (issue #140)
# Wired via the package.json "prepare" script (git config core.hooksPath .githooks),
# so it propagates to every clone/CI on `npm install`.
#
# Bypass for a verified false positive / WIP commit: git commit --no-verify

set -e
ROOT="$(git rev-parse --show-toplevel)"

# 1. Secret guard (issue #122)
node "$ROOT/scripts/check-secrets.mjs"

# 2. IICRC CEC terminology guard (Linear GP-451) — staged additions only.
node "$ROOT/scripts/check-iicrc-terminology.mjs" --staged

# 3. Incremental type-check (issue #140). The build-info cache lives under
#    node_modules/.cache (already gitignored) so no .tsbuildinfo is ever committed.
mkdir -p "$ROOT/node_modules/.cache"
if ! npx --no-install tsc --noEmit --incremental \
  --tsBuildInfoFile "$ROOT/node_modules/.cache/carsi-tsbuildinfo"; then
  echo "✖ pre-commit: tsc --noEmit found type errors. Fix them, or use 'git commit --no-verify' for a WIP commit." >&2
  exit 1
fi
