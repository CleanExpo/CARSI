// LMS tables originally seeded from the one-time WordPress migration (committed exports in data/wordpress-export + SQL loaders). Run `pnpm prisma:pull` when your DB is up to sync with production.
// When your Postgres is running, run `pnpm prisma:pull` (or `npx prisma db pull`) to replace this with an exact introspection of your database.
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model LmsRole {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  userRoles LmsUserRole[]

  @@map("lms_roles")
}

model LmsUser {
  id                         String    @id @db.Uuid
  email                      String    @unique
  hashedPassword             String    @map("hashed_password")
  fullName                   String?   @map("full_name")
  isActive                   Boolean   @default(true) @map("is_active")
  isVerified                 Boolean   @default(false) @map("is_verified")
  themePreference            String?   @map("theme_preference")
  /// Present in some deployments (`scripts/seed_production.py`); omit in queries if unused.
  role                       String?
  iicrcMemberNumber          String?   @map("iicrc_member_number")
  iicrcExpiryDate            DateTime? @map("iicrc_expiry_date") @db.Date
  iicrcCardImageUrl          String?   @map("iicrc_card_image_url") @db.Text
  iicrcCertifications        Json?     @map("iicrc_certifications")
  /// First-run dashboard onboarding (industry, disciplines, goals). Set when wizard completes.
  onboardingCompletedAt      DateTime? @map("onboarding_completed_at") @db.Timestamptz(6)
  /// JSON: industry, role, iicrc_experience, disciplines_held[], primary_goal, etc.
  onboarding                 Json?
  /// none | email | sms — preference for unfinished-lesson reminders (delivery not yet wired for sms).
  resumeReminderOptIn        String?   @map("resume_reminder_opt_in")
  /// Marketing-style email opt-out (Australian Spam Act). When true, the monthly toolbox-talk drip
  /// email is suppressed. In-app notifications and compliance (recert) emails are NOT affected.
  emailOptOut                Boolean   @default(false) @map("email_opt_out")
  /// When true, `leaderboardDisplayName` may appear on the monthly leaderboard; otherwise an anonymous label is shown.
  leaderboardShowDisplayName Boolean   @default(false) @map("leaderboard_show_display_name")
  /// Optional public label for the monthly leaderboard only (never auto-filled from legal name).
  leaderboardDisplayName     String?   @map("leaderboard_display_name") @db.VarChar(48)
  createdAt                  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  userRoles             LmsUserRole[]
  enrollments           LmsEnrollment[]           @relation("EnrollmentStudent")
  coursesInstructing    LmsCourse[]               @relation("CourseInstructor")
  userDiscounts         UserDiscount[]
  teamMemberships       LmsTeamMember[]
  ownedTeams            LmsTeam[]                 @relation("TeamOwner")
  quizAttempts          LmsQuizAttempt[]
  assessmentSubmissions LmsAssessmentSubmission[] @relation("AssessmentSubmissionStudent")
  assessmentReviews     LmsAssessmentSubmission[] @relation("AssessmentSubmissionReviewer")
  iicrcCecSubmissions   LmsIicrcCecSubmission[]
  lessonProgress        LmsLessonProgress[]
  lessonNotes           LmsLessonNote[]
  notifications         LmsNotification[]
  courseReviews         LmsCourseReview[]         @relation("ReviewStudent")
  reviewReplies         LmsCourseReview[]         @relation("ReviewReplyAuthor")
  subscription          LmsSubscription?
  margotConversations   MargotConversation[]
  ccwRoadshowSignIns    CcwRoadshowSignIn[]       @relation("SignInStudent")

  @@map("lms_users")
}

/// Private per-student note attached to a lesson. Durable replacement for the former in-memory
/// stub (GP-459). Upserted by (user_id, lesson_id); the denormalised course/lesson/module titles
/// let `GET /api/lms/notes/me` render the notes list without joining the (external) course catalogue.
model LmsLessonNote {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  lessonId    String   @map("lesson_id")
  content     String   @db.Text
  /// Denormalised display metadata captured at save time (course catalogue lives outside this DB).
  lessonTitle String?  @map("lesson_title")
  moduleTitle String?  @map("module_title")
  courseTitle String?  @map("course_title")
  courseSlug  String?  @map("course_slug")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user LmsUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, updatedAt])
  @@map("lms_lesson_notes")
}

/// In-app (and optionally emailable) notifications: toolbox-talk drip, recert reminders, system.
/// Idempotent on `dedupe_key` (type + subject + period + user) so crons can re-run safely.
model LmsNotification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  /// 'toolbox_talk' | 'recert_due' | 'system' | …
  type      String
  title     String
  body      String    @db.Text
  linkUrl   String?   @map("link_url") @db.Text
  /// Idempotency key — a unique upsert target so the same notification is never created twice.
  dedupeKey String    @unique @map("dedupe_key")
  readAt    DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user LmsUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("lms_notifications")
}

/// Junction table: `ON CONFLICT DO NOTHING` on (user_id, role_id) in loaders.
model LmsUserRole {
  userId String @map("user_id") @db.Uuid
  roleId Int    @map("role_id")

  user LmsUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role LmsRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("lms_user_roles")
}

model LmsCourse {
  id               String   @id @db.Uuid
  slug             String   @unique
  title            String
  description      String?  @db.Text
  shortDescription String?  @map("short_description") @db.Text
  thumbnailUrl     String?  @map("thumbnail_url")
  instructorId     String   @map("instructor_id") @db.Uuid
  status           String
  priceAud         Decimal  @map("price_aud") @db.Decimal(12, 2)
  isFree           Boolean  @default(false) @map("is_free")
  durationHours    Float?   @map("duration_hours")
  level            String?
  category         String?
  tags             Json?
  iicrcDiscipline  String?  @map("iicrc_discipline")
  cecHours         Float?   @map("cec_hours")
  meta             Json?
  isPublished      Boolean? @map("is_published")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  instructor           LmsUser                    @relation("CourseInstructor", fields: [instructorId], references: [id])
  modules              LmsModule[]
  enrollments          LmsEnrollment[]
  userDiscounts        UserDiscount[]
  pathwayCourses       LmsLearningPathwayCourse[]
  quizzes              LmsQuiz[]
  practicalAssessments LmsPracticalAssessment[]
  iicrcCecSubmissions  LmsIicrcCecSubmission[]
  reviews              LmsCourseReview[]

  @@index([instructorId], map: "ix_lms_courses_instructor_id")
  @@map("lms_courses")
}

/// Student course reviews / star ratings (1–5). One review per student per course
/// (`uq_lms_course_review`), gated on an existing enrolment. `isPublished` lets an
/// admin hide a review without deleting it; public listings filter on it.
model LmsCourseReview {
  id          String    @id @default(uuid()) @db.Uuid
  courseId    String    @map("course_id") @db.Uuid
  studentId   String    @map("student_id") @db.Uuid
  rating      Int
  title       String?   @db.Text
  body        String?   @db.Text
  isPublished Boolean   @default(true) @map("is_published")
  /// Public instructor/admin response to the review (GP-118).
  reply       String?   @db.Text
  repliedAt   DateTime? @map("replied_at") @db.Timestamptz(6)
  repliedById String?   @map("replied_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  course    LmsCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   LmsUser   @relation("ReviewStudent", fields: [studentId], references: [id], onDelete: Cascade)
  repliedBy LmsUser?  @relation("ReviewReplyAuthor", fields: [repliedById], references: [id], onDelete: SetNull)

  @@unique([courseId, studentId], map: "uq_lms_course_review")
  @@index([courseId, isPublished], map: "ix_lms_course_review_course_published")
  @@map("lms_course_reviews")
}

enum DiscountType {
  percentage
  flat
  free
  custom
}

/// Per-user, per-course pricing overrides managed in admin (`/admin/discounts`).
model UserDiscount {
  id            String       @id @default(uuid()) @db.Uuid
  userId        String       @map("user_id") @db.Uuid
  courseId      String       @map("course_id") @db.Uuid
  discountType  DiscountType @map("discount_type")
  /// Percentage (0–100), flat AUD off, custom AUD price; null when `free`.
  discountValue Decimal?     @map("discount_value") @db.Decimal(12, 2)
  expiryDate    DateTime?    @map("expiry_date") @db.Timestamptz(6)
  note          String?      @db.Text
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  user   LmsUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course LmsCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId, courseId])
  @@map("user_discounts")
}

model LmsModule {
  id         String   @id @db.Uuid
  courseId   String   @map("course_id") @db.Uuid
  title      String
  orderIndex Int      @map("order_index")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  course  LmsCourse   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons LmsLesson[]

  @@index([courseId], map: "ix_lms_modules_course_id")
  @@map("lms_modules")
}

model LmsLesson {
  id          String   @id @db.Uuid
  moduleId    String   @map("module_id") @db.Uuid
  title       String
  contentType String   @map("content_type")
  contentBody String?  @map("content_body") @db.Text
  orderIndex  Int      @map("order_index")
  isPreview   Boolean  @default(false) @map("is_preview")
  resources   Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  module          LmsModule           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progressRecords LmsLessonProgress[]

  @@index([moduleId], map: "ix_lms_lessons_module_id")
  @@map("lms_lessons")
}

model LmsLessonProgress {
  id             String    @id @default(uuid()) @db.Uuid
  studentId      String    @map("student_id") @db.Uuid
  lessonId       String    @map("lesson_id") @db.Uuid
  completed      Boolean   @default(false)
  completedAt    DateTime? @map("completed_at") @db.Timestamptz(6)
  lastAccessedAt DateTime  @default(now()) @map("last_accessed_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  lesson  LmsLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student LmsUser   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId], map: "uq_lms_lesson_progress_student_lesson")
  @@index([lessonId], map: "ix_lms_lesson_progress_lesson_id")
  @@map("lms_lesson_progress")
}

/// Unique enrollment per student/course: constraint `uq_lms_enrollment` in migration loaders.
model LmsEnrollment {
  id                   String    @id @db.Uuid
  studentId            String    @map("student_id") @db.Uuid
  courseId             String    @map("course_id") @db.Uuid
  status               String
  paymentReference     String?   @map("payment_reference")
  enrolledAt           DateTime  @default(now()) @map("enrolled_at") @db.Timestamptz(6)
  lastAccessedLessonId String?   @map("last_accessed_lesson_id") @db.Uuid
  completedAt          DateTime? @map("completed_at") @db.Timestamptz(6)
  certificateIssuedAt  DateTime? @map("certificate_issued_at") @db.Timestamptz(6)
  /// Why a revoked row was revoked: 'disputed' | 'refunded' (null when active).
  /// A dispute-won re-grant reactivates ONLY 'disputed' rows; a later refund
  /// downgrades a 'disputed' row to 'refunded' so it can never be re-granted.
  revokedReason        String?   @map("revoked_reason")
  /// Stripe `event.created` of the last status-changing reversal event
  /// (dispute/refund) applied to this row. Out-of-order guard: a revoke or
  /// dispute-won reactivate ignores an event older than this stamp, so a
  /// retried/late webhook can't overwrite a newer decision. Null for rows never
  /// touched by a reversal event (the guard then treats them as unconstrained).
  statusEventAt        DateTime? @map("status_event_at") @db.Timestamptz(6)

  student            LmsUser                @relation("EnrollmentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  course             LmsCourse              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  iicrcCecSubmission LmsIicrcCecSubmission?
  ccwRoadshowSignIn  CcwRoadshowSignIn?     @relation("SignInEnrollment")

  @@unique([studentId, courseId], map: "uq_lms_enrollment")
  @@index([courseId], map: "ix_lms_enrollments_course_id")
  @@map("lms_enrollments")
}

/// Auto-submitted IICRC CEC certificate emails (renewals@iicrcnet.org) on course completion.
model LmsIicrcCecSubmission {
  id                    String    @id @default(uuid()) @db.Uuid
  enrollmentId          String    @unique @map("enrollment_id") @db.Uuid
  studentId             String    @map("student_id") @db.Uuid
  courseId              String    @map("course_id") @db.Uuid
  recipientEmail        String    @map("recipient_email") @db.VarChar(320)
  technicianEmail       String    @map("technician_email") @db.VarChar(320)
  /// Delivery status: pending | sent | failed | skipped
  status                String    @default("pending") @db.VarChar(16)
  /// Workflow status: pending | sent | awaiting_response | approved | rejected | completed | skipped | failed
  renewalStatus         String    @default("pending") @map("renewal_status") @db.VarChar(24)
  initiatedByAdminEmail String?   @map("initiated_by_admin_email") @db.VarChar(320)
  cecHours              Float?    @map("cec_hours")
  iicrcDiscipline       String?   @map("iicrc_discipline") @db.VarChar(16)
  iicrcMemberNumber     String?   @map("iicrc_member_number") @db.VarChar(32)
  emailSubject          String?   @map("email_subject") @db.Text
  emailTextBody         String?   @map("email_text_body") @db.Text
  emailHtmlBody         String?   @map("email_html_body") @db.Text
  ccEmails              String?   @map("cc_emails") @db.Text
  providerMessageId     String?   @map("provider_message_id") @db.VarChar(128)
  failureReason         String?   @map("failure_reason") @db.Text
  sentAt                DateTime? @map("sent_at") @db.Timestamptz(6)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // WS6 regulatory retention (P1): an IICRC CEC submission is a compliance record
  // filed with the regulator — it must NEVER be cascade-erased by deleting a
  // learner, enrolment, or course. Restrict blocks the parent delete instead
  // (all three FK columns are NOT NULL, so SetNull is not possible). App delete
  // paths pre-check for a CEC record and soft-handle it.
  enrollment     LmsEnrollment               @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  student        LmsUser                     @relation(fields: [studentId], references: [id], onDelete: Restrict)
  course         LmsCourse                   @relation(fields: [courseId], references: [id], onDelete: Restrict)
  communications LmsIicrcCecCommunication[]
  notes          LmsIicrcCecSubmissionNote[]

  @@index([studentId])
  @@index([status])
  @@index([renewalStatus])
  @@index([sentAt])
  @@map("lms_iicrc_cec_submissions")
}

/// Individual email in the renewal communication audit trail (outbound or inbound).
model LmsIicrcCecCommunication {
  id                    String    @id @default(uuid()) @db.Uuid
  submissionId          String    @map("submission_id") @db.Uuid
  enrollmentId          String    @map("enrollment_id") @db.Uuid
  studentId             String    @map("student_id") @db.Uuid
  courseId              String    @map("course_id") @db.Uuid
  /// outbound | inbound
  direction             String    @db.VarChar(12)
  /// iicrc_submission | technician_receipt | inbound_reply | admin_manual
  kind                  String    @db.VarChar(24)
  initiatedByAdminEmail String?   @map("initiated_by_admin_email") @db.VarChar(320)
  fromEmail             String    @map("from_email") @db.VarChar(320)
  toEmails              String    @map("to_emails") @db.Text
  ccEmails              String?   @map("cc_emails") @db.Text
  subject               String    @db.Text
  textBody              String?   @map("text_body") @db.Text
  htmlBody              String?   @map("html_body") @db.Text
  /// pending | sent | delivered | failed | bounced | skipped
  deliveryStatus        String    @default("pending") @map("delivery_status") @db.VarChar(16)
  providerMessageId     String?   @map("provider_message_id") @db.VarChar(128)
  failureReason         String?   @map("failure_reason") @db.Text
  sentAt                DateTime? @map("sent_at") @db.Timestamptz(6)
  receivedAt            DateTime? @map("received_at") @db.Timestamptz(6)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  submission  LmsIicrcCecSubmission                @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  attachments LmsIicrcCecCommunicationAttachment[]

  @@index([submissionId])
  @@index([studentId])
  @@index([enrollmentId])
  @@index([createdAt])
  @@map("lms_iicrc_cec_communications")
}

model LmsIicrcCecCommunicationAttachment {
  id              String @id @default(uuid()) @db.Uuid
  communicationId String @map("communication_id") @db.Uuid
  filename        String @db.VarChar(255)
  mimeType        String @map("mime_type") @db.VarChar(128)
  sizeBytes       Int?   @map("size_bytes")
  /// outbound | inbound
  direction       String @db.VarChar(12)

  communication LmsIicrcCecCommunication @relation(fields: [communicationId], references: [id], onDelete: Cascade)

  @@index([communicationId])
  @@map("lms_iicrc_cec_communication_attachments")
}

/// Internal admin notes and follow-up actions for a renewal submission.
model LmsIicrcCecSubmissionNote {
  id               String    @id @default(uuid()) @db.Uuid
  submissionId     String    @map("submission_id") @db.Uuid
  authorAdminEmail String    @map("author_admin_email") @db.VarChar(320)
  body             String    @db.Text
  followUpAction   String?   @map("follow_up_action") @db.Text
  followUpDueAt    DateTime? @map("follow_up_due_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  submission LmsIicrcCecSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("lms_iicrc_cec_submission_notes")
}

model LmsCategory {
  id          String  @id @db.Uuid
  slug        String  @unique
  name        String
  description String? @db.Text
  parentId    String? @map("parent_id") @db.Uuid
  orderIndex  Int?    @map("order_index")

  @@map("lms_categories")
}

model LmsLearningPathway {
  id                  String  @id @db.Uuid
  slug                String  @unique
  title               String
  description         String? @db.Text
  iicrcDiscipline     String? @map("iicrc_discipline")
  targetCertification String? @map("target_certification") @db.Text
  estimatedHours      Float?  @map("estimated_hours")
  isPublished         Boolean @default(false) @map("is_published")
  orderIndex          Int     @default(0) @map("order_index")

  courses LmsLearningPathwayCourse[]

  @@map("lms_learning_pathways")
}

model LmsLearningPathwayCourse {
  pathwayId  String @map("pathway_id") @db.Uuid
  courseId   String @map("course_id") @db.Uuid
  orderIndex Int    @default(0) @map("order_index")

  pathway LmsLearningPathway @relation(fields: [pathwayId], references: [id], onDelete: Cascade)
  course  LmsCourse          @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([pathwayId, courseId])
  @@map("lms_learning_pathway_courses")
}

/// Course quiz (Phase 2) — linked from lessons with content_type `quiz`.
model LmsQuiz {
  id               String   @id @default(uuid()) @db.Uuid
  courseId         String   @map("course_id") @db.Uuid
  title            String
  passPercentage   Int      @default(70) @map("pass_percentage")
  timeLimitMinutes Int?     @map("time_limit_minutes")
  attemptsAllowed  Int      @default(3) @map("attempts_allowed")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  course    LmsCourse         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions LmsQuizQuestion[]
  attempts  LmsQuizAttempt[]

  @@index([courseId])
  @@map("lms_quizzes")
}

model LmsQuizQuestion {
  id           String @id @default(uuid()) @db.Uuid
  quizId       String @map("quiz_id") @db.Uuid
  questionText String @map("question_text") @db.Text
  options      Json
  correctIndex Int    @map("correct_index")
  orderIndex   Int    @default(0) @map("order_index")
  points       Int    @default(1)

  quiz LmsQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@map("lms_quiz_questions")
}

model LmsQuizAttempt {
  id           String   @id @default(uuid()) @db.Uuid
  quizId       String   @map("quiz_id") @db.Uuid
  studentId    String   @map("student_id") @db.Uuid
  scorePercent Int      @map("score_percent")
  passed       Boolean
  answers      Json
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  quiz    LmsQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student LmsUser @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([quizId, studentId])
  @@map("lms_quiz_attempts")
}

/// Practical (instructor-graded) assessment attached to a course, with a scoring rubric (GP-457).
model LmsPracticalAssessment {
  id            String   @id @default(uuid()) @db.Uuid
  courseId      String   @map("course_id") @db.Uuid
  title         String
  instructions  String   @db.Text
  /// Minimum % of total rubric points required to pass.
  passThreshold Int      @default(70) @map("pass_threshold")
  isPublished   Boolean  @default(false) @map("is_published")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  course      LmsCourse                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  criteria    LmsRubricCriterion[]
  submissions LmsAssessmentSubmission[]

  @@index([courseId])
  @@map("lms_practical_assessments")
}

/// One rubric criterion for a practical assessment (GP-457).
model LmsRubricCriterion {
  id           String @id @default(uuid()) @db.Uuid
  assessmentId String @map("assessment_id") @db.Uuid
  label        String
  description  String @default("") @db.Text
  maxPoints    Int    @default(5) @map("max_points")
  orderIndex   Int    @default(0) @map("order_index")

  assessment LmsPracticalAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@map("lms_rubric_criteria")
}

/// A student submission for a practical assessment + its instructor review (GP-457).
model LmsAssessmentSubmission {
  id              String    @id @default(uuid()) @db.Uuid
  assessmentId    String    @map("assessment_id") @db.Uuid
  studentId       String    @map("student_id") @db.Uuid
  evidenceText    String    @map("evidence_text") @db.Text
  /// Optional evidence links; portfolio file uploads are tracked separately (GP-122).
  evidenceUrls    Json      @default("[]") @map("evidence_urls")
  /// pending | under_review | passed | failed
  status          String    @default("pending")
  /// JSON array of { criterionId, points, comment } captured at review time.
  criterionScores Json      @default("[]") @map("criterion_scores")
  totalScore      Int?      @map("total_score")
  reviewerId      String?   @map("reviewer_id") @db.Uuid
  reviewerNotes   String?   @map("reviewer_notes") @db.Text
  reviewedAt      DateTime? @map("reviewed_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  assessment LmsPracticalAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student    LmsUser                @relation("AssessmentSubmissionStudent", fields: [studentId], references: [id], onDelete: Cascade)
  reviewer   LmsUser?               @relation("AssessmentSubmissionReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([assessmentId])
  @@index([studentId])
  @@index([status])
  @@map("lms_assessment_submissions")
}

/// B2B team (Phase 2) — seat-based bundles.
model LmsTeam {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  slug       String   @unique
  ownerId    String   @map("owner_id") @db.Uuid
  bundleTier String   @map("bundle_tier") @db.VarChar(32)
  courseSlug String?  @map("course_slug") @db.VarChar(128)
  seatLimit  Int      @default(5) @map("seat_limit")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // WS6 (P1): don't destroy a team + its Stripe-linked subscriptions when the
  // owner account is deleted. Restrict forces an ownership transfer first
  // (ownerId is NOT NULL, so SetNull would break the billing/seat invariant).
  owner            LmsUser                 @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members          LmsTeamMember[]
  invites          LmsTeamInvite[]
  coursePurchases  LmsTeamCoursePurchase[]
  teamSubscription LmsTeamSubscription?
  orgSubscription  LmsOrgSubscription?

  @@map("lms_teams")
}

/// Seats purchased for a specific course on a team (one row per team checkout).
model LmsTeamCoursePurchase {
  id               String   @id @default(uuid()) @db.Uuid
  teamId           String   @map("team_id") @db.Uuid
  courseSlug       String   @map("course_slug") @db.VarChar(128)
  seatLimit        Int      @map("seat_limit")
  paymentReference String?  @map("payment_reference") @db.VarChar(255)
  purchasedAt      DateTime @default(now()) @map("purchased_at") @db.Timestamptz(6)

  team LmsTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([courseSlug])
  @@map("lms_team_course_purchases")
}

model LmsTeamMember {
  teamId   String   @map("team_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  role     String   @default("member") @db.VarChar(16)
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz(6)

  team LmsTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user LmsUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@map("lms_team_members")
}

model LmsTeamInvite {
  id         String    @id @default(uuid()) @db.Uuid
  teamId     String    @map("team_id") @db.Uuid
  email      String    @db.VarChar(320)
  role       String    @default("member") @db.VarChar(16)
  token      String    @unique
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  acceptedAt DateTime? @map("accepted_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  team LmsTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([email])
  @@map("lms_team_invites")
}

/// RA-3027 — replaces the single ADMIN_EMAIL+ADMIN_PASSWORD env-var gate
/// for the CARSI admin surface. Multiple admins, per-admin password hash
/// (bcryptjs), per-admin role, audit-able lastLoginAt.
///
/// Migration semantics: backwards-compatible — the env-var login path
/// remains active until at least one row exists in this table. See
/// `docs/ADMIN_AUTH_MIGRATION.md` for rollout steps.
/// Public contact form (`/contact`) — Phase 1 inbox.
model ContactSubmission {
  id        String   @id @default(uuid()) @db.Uuid
  firstName String   @map("first_name") @db.VarChar(120)
  lastName  String   @map("last_name") @db.VarChar(120)
  email     String   @db.VarChar(320)
  message   String   @db.Text
  status    String   @default("new") @db.VarChar(32)
  sourceIp  String?  @map("source_ip") @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  replyDrafts ContactReplyDraft[]

  @@index([status, createdAt(sort: Desc)])
  @@index([email])
  @@map("contact_submissions")
}

/// IICRC-grounded contact replies (Phase 2). An AI draft (or a human's inline
/// reply) plus the provenance/audit record for every outbound. A `pending_approval`
/// draft that cleared the deterministic gates (no-verbatim + judge) is auto-sent
/// once the 2h SLA elapses with no human reply (founder-authorized 2026-07-01).
/// See docs/specs/2026-07-01-carsi-assistant-and-contact-reply.md §14a.
model ContactReplyDraft {
  id               String    @id @default(uuid()) @db.Uuid
  submissionId     String?   @map("submission_id") @db.Uuid
  recipientEmail   String    @map("recipient_email") @db.VarChar(320)
  recipientName    String    @map("recipient_name") @db.VarChar(240)
  question         String    @db.Text
  replyBody        String    @map("reply_body") @db.Text
  standardsCited   String[]  @map("standards_cited")
  stormSources     Json      @map("storm_sources")
  judgeVerdict     Json?     @map("judge_verdict")
  /// Always "pass" — a draft that fails the >= 8-gram guard is never persisted.
  ngramCheck       String    @default("pass") @map("ngram_check") @db.VarChar(16)
  /// Cleared judge + no-verbatim gates → eligible for 2h auto-send.
  autoSendEligible Boolean   @default(false) @map("auto_send_eligible")
  /// "agent:<skill>" for an AI draft, "admin:<email>" for an inline human reply.
  draftedBy        String    @map("drafted_by") @db.VarChar(160)
  /// Human email who approved, or "auto:sla-2h" when the SLA fired. Null while pending.
  approvedBy       String?   @map("approved_by") @db.VarChar(320)
  /// "human" | "auto" — how the send was triggered.
  sentVia          String?   @map("sent_via") @db.VarChar(16)
  /// "pending_approval" | "sent" | "discarded".
  status           String    @default("pending_approval") @db.VarChar(32)
  sentAt           DateTime? @map("sent_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  submission ContactSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([submissionId])
  @@map("contact_reply_drafts")
}

/// Outbound CRM/webhook events (Phase 3) — contact, enrollment, etc.
model CrmEventLog {
  id             String   @id @default(uuid()) @db.Uuid
  eventType      String   @map("event_type") @db.VarChar(64)
  payload        Json
  status         String   @default("pending") @db.VarChar(32)
  responseStatus Int?     @map("response_status")
  responseBody   String?  @map("response_body") @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([eventType, createdAt(sort: Desc)])
  @@index([status])
  @@map("crm_event_logs")
}

/// Industry Hub intake (`/submit/*`) — podcasts, professionals, events, etc.
model HubSubmission {
  id                    String   @id @default(uuid()) @db.Uuid
  submissionType        String   @map("submission_type") @db.VarChar(32)
  status                String   @default("pending") @db.VarChar(32)
  submitterName         String   @map("submitter_name") @db.VarChar(200)
  submitterEmail        String   @map("submitter_email") @db.VarChar(320)
  submitterPhone        String?  @map("submitter_phone") @db.VarChar(64)
  submitterCompany      String?  @map("submitter_company") @db.VarChar(200)
  submitterRole         String?  @map("submitter_role") @db.VarChar(200)
  submissionTitle       String   @map("submission_title") @db.VarChar(300)
  submissionUrl         String?  @map("submission_url") @db.Text
  submissionDescription String?  @map("submission_description") @db.Text
  submissionData        Json     @default("{}") @map("submission_data")
  termsAccepted         Boolean  @map("terms_accepted")
  guidelinesAccepted    Boolean  @map("guidelines_accepted")
  ipAddress             String?  @map("ip_address") @db.VarChar(64)
  userAgent             String?  @map("user_agent") @db.VarChar(512)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([submissionType, status, createdAt(sort: Desc)])
  @@index([submitterEmail])
  @@map("hub_submissions")
}

/// Stripe webhook idempotency guard. Stripe delivers webhooks at least once,
/// so handlers must claim event IDs before side effects and skip replays.
model StripeWebhookEvent {
  id          String    @id
  type        String    @db.VarChar(128)
  processedAt DateTime? @map("processed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("stripe_webhook_events")
}

/// Pseudonymous first-party event-to-revenue attribution ledger for the July
/// 2026 CARSI x CCW Business Growth Days. `journeyId` is an opaque, linkable UUID
/// stored in an HttpOnly cookie after successful attributed event registration.
/// Rows are excluded after 90 days and opportunistically deleted by the service.
model EventAttributionEvent {
  id                   String    @id @default(uuid()) @db.Uuid
  journeyId            String    @map("journey_id") @db.Uuid
  campaignId           String    @map("campaign_id") @db.VarChar(80)
  sourceId             String    @map("source_id") @db.VarChar(40)
  eventSlug            String    @map("event_slug") @db.VarChar(32)
  stage                String    @db.VarChar(32)
  courseSlug           String?   @map("course_slug") @db.VarChar(200)
  revenueCents         Int?      @map("revenue_cents")
  currency             String?   @db.VarChar(3)
  transactionId        String?   @map("transaction_id") @db.VarChar(255)
  reversedRevenueCents Int       @default(0) @map("reversed_revenue_cents")
  reversalReason       String?   @map("reversal_reason") @db.VarChar(32)
  reversalEventId      String?   @map("reversal_event_id") @db.VarChar(255)
  reversalEventAt      DateTime? @map("reversal_event_at") @db.Timestamptz(6)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([stage, transactionId])
  @@index([campaignId, sourceId, stage])
  @@index([journeyId, createdAt])
  @@index([createdAt])
  @@map("event_attribution_events")
}

/// One row per learner; mirrors the Stripe subscription lifecycle. The
/// `getEntitlements` service reads `status` + `currentPeriodEnd` to decide new-
/// enrolment access (active / 7-day past-due grace / lapsed). Additive table —
/// no existing one-off purchase flow depends on it.
model LmsSubscription {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @unique @map("user_id") @db.Uuid
  stripeCustomerId     String?   @map("stripe_customer_id") @db.VarChar(255)
  /// Unique when present so a replayed webhook cannot create a second row.
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id") @db.VarChar(255)
  /// Stripe subscription status: active | trialing | past_due | canceled | unpaid | incomplete | incomplete_expired.
  status               String    @db.VarChar(32)
  /// Plan identifier for UI (currently always `pro_annual`).
  plan                 String    @default("pro_annual") @map("plan") @db.VarChar(32)
  currentPeriodEnd     DateTime? @map("current_period_end") @db.Timestamptz(6)
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  /// Stripe event.created of the snapshot that last set `status`. Out-of-order
  /// guard: a snapshot is applied only when its event timestamp is >= this.
  /// NULL = no ordered write yet (always overwritable; pre-migration rows).
  statusEventAt        DateTime? @map("status_event_at") @db.Timestamptz(6)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user LmsUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId], map: "idx_lms_subscriptions_customer")
  @@map("lms_subscriptions")
}

/// WS1-E2 (GP-442): seat-based Teams subscription. A recurring Stripe
/// subscription whose `quantity` is the seat count; while `active`/in grace,
/// exactly `seatLimit` members of the team hold whole-catalogue entitlement.
/// Parallels `LmsSubscription` (individual) but is keyed on the team, so a team
/// has at most one active seat subscription. Distinct from the one-off,
/// per-course `LmsTeamCoursePurchase` block — this is recurring + all-courses.
model LmsTeamSubscription {
  id                   String    @id @default(uuid()) @db.Uuid
  teamId               String    @unique @map("team_id") @db.Uuid
  stripeCustomerId     String?   @map("stripe_customer_id") @db.VarChar(255)
  /// Unique when present so a replayed webhook cannot create a second row.
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id") @db.VarChar(255)
  /// Stripe subscription status: active | trialing | past_due | canceled | unpaid | incomplete | incomplete_expired.
  status               String    @db.VarChar(32)
  /// Teams tier id for UI: starter | growth | full_library.
  plan                 String    @default("starter") @map("plan") @db.VarChar(32)
  /// Purchased seat count (= Stripe subscription quantity). Members beyond this
  /// index are NOT entitled; the owner expands by increasing the quantity.
  seatLimit            Int       @map("seat_limit")
  currentPeriodEnd     DateTime? @map("current_period_end") @db.Timestamptz(6)
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  /// Out-of-order guard — see LmsSubscription.statusEventAt.
  statusEventAt        DateTime? @map("status_event_at") @db.Timestamptz(6)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  team LmsTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId], map: "idx_lms_team_subscriptions_customer")
  @@map("lms_team_subscriptions")
}

/// WS1-E3 (GP-443): organisation monthly subscription (A$1,295/month + GST,
/// unlimited learners). Executes docs/plans/2026-06-27-org-subscription-billing.md.
/// Reuses `LmsTeam` as the organisation container (members link via LmsTeamMember);
/// entitlement = "member of an org whose subscription is active and which entitles
/// this course category". `seatModel` is always 'unlimited' for this plan.
model LmsOrgSubscription {
  id                   String    @id @default(uuid()) @db.Uuid
  teamId               String    @unique @map("team_id") @db.Uuid
  organisationName     String    @map("organisation_name") @db.VarChar(255)
  contactEmail         String    @map("contact_email") @db.VarChar(320)
  stripeCustomerId     String?   @map("stripe_customer_id") @db.VarChar(255)
  /// Unique when present so a replayed webhook cannot create a second row.
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id") @db.VarChar(255)
  /// Stripe subscription status: active | trialing | past_due | canceled | unpaid | incomplete | incomplete_expired.
  status               String    @db.VarChar(32)
  plan                 String    @default("org_monthly") @map("plan") @db.VarChar(32)
  /// Seat model — always 'unlimited' for the org monthly plan.
  seatModel            String    @default("unlimited") @map("seat_model") @db.VarChar(16)
  /// Course category this subscription entitles (the CARSI Maintenance Company
  /// Onboarding brand). Members enrol freely in courses in this category.
  entitledCategory     String    @default("CARSI Maintenance Company Onboarding") @map("entitled_category") @db.VarChar(128)
  currentPeriodEnd     DateTime? @map("current_period_end") @db.Timestamptz(6)
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  /// Out-of-order guard — see LmsSubscription.statusEventAt.
  statusEventAt        DateTime? @map("status_event_at") @db.Timestamptz(6)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  team LmsTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId], map: "idx_lms_org_subscriptions_customer")
  @@map("lms_org_subscriptions")
}

model AdminUser {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         String    @default("admin")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(6)
  lastLoginIp  String?   @map("last_login_ip")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("admin_users")
}

model CcwRoadshowRegistration {
  id                String   @id @default(uuid()) @db.Uuid
  eventSlug         String   @map("event_slug") @db.VarChar(32)
  freeEntryToken    String   @unique @map("free_entry_token")
  companyName       String?  @map("company_name")
  contactEmail      String   @map("contact_email")
  contactPhone      String?  @map("contact_phone")
  ccwCustomerStatus String?  @map("ccw_customer_status") @db.VarChar(40)
  seatCount         Int      @map("seat_count")
  status            String   @default("confirmed") @db.VarChar(20)
  calendarSynced    Boolean  @default(false) @map("calendar_synced")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  attendees CcwRoadshowAttendee[]
  signIns   CcwRoadshowSignIn[]
  emails    CcwRoadshowEmailLog[]

  @@index([eventSlug, status])
  @@index([eventSlug, createdAt(sort: Asc)])
  @@map("ccw_roadshow_registrations")
}

/// Delivery record for every roadshow attendee email we ATTEMPT (confirmed /
/// waitlisted / promoted).
///
/// Why this exists: `sendEmail()` reports failure by RETURNING
/// `{ sent: false, reason }` rather than throwing, so a failed send used to be
/// invisible — the promote route's try/catch never fired, the return value was
/// discarded, and nothing was recorded. One row per attempt makes
/// "was this person actually emailed?" answerable.
///
/// Mirrors the delivery fields on LmsIicrcCecCommunication.
model CcwRoadshowEmailLog {
  id                String    @id @default(uuid()) @db.Uuid
  registrationId    String    @map("registration_id") @db.Uuid
  /// confirmed | waitlisted | promoted
  kind              String    @db.VarChar(16)
  recipientEmail    String    @map("recipient_email")
  /// sent | failed | skipped
  deliveryStatus    String    @map("delivery_status") @db.VarChar(16)
  /// SendEmailResult.reason — not_configured | send_failed | provider_error | dev_console
  failureReason     String?   @map("failure_reason") @db.Text
  providerMessageId String?   @map("provider_message_id") @db.VarChar(128)
  sentAt            DateTime? @map("sent_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  registration CcwRoadshowRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@index([deliveryStatus])
  @@index([createdAt])
  @@map("ccw_roadshow_email_logs")
}

model CcwRoadshowAttendee {
  id              String   @id @default(uuid()) @db.Uuid
  registrationId  String   @map("registration_id") @db.Uuid
  fullName        String   @map("full_name")
  yearsExperience String   @map("years_experience") @db.VarChar(16)
  goals           String   @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  registration CcwRoadshowRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@map("ccw_roadshow_attendees")
}

/// CCW/CARSI 2-day-workshop attendance foundation (unit A). One row per PERSON per EVENT.
/// The two day-columns here are the WRITE-ONCE source of truth for attendance
/// (set-if-null on check-in; admin corrections are direct, write-once-respecting
/// updates). Both days set → certificate of attendance (no CEC — this course
/// promotes CCW commercial products, so IICRC will not grant CECs).
/// Everything is DARK behind the `CCW_ATTENDANCE_ENABLED` env flag.
model CcwRoadshowSignIn {
  id                 String    @id @default(uuid()) @db.Uuid
  eventSlug          String    @map("event_slug") @db.VarChar(32)
  /// Null = walk-in (no pre-registration matched). FK is SET NULL on registration delete.
  registrationId     String?   @map("registration_id") @db.Uuid
  /// Set once the attendee has been provisioned a CARSI account (async batch).
  studentId          String?   @map("student_id") @db.Uuid
  /// Set once the attendee is enrolled in the 2-day course (async batch).
  enrollmentId       String?   @map("enrollment_id") @db.Uuid
  fullName           String    @map("full_name")
  businessName       String?   @map("business_name")
  email              String    @db.VarChar(320)
  normalizedEmail    String    @map("normalized_email") @db.VarChar(320)
  normalizedBusiness String?   @map("normalized_business")
  normalizedName     String    @map("normalized_name")
  /// Write-once (set-if-null). Admin corrections are direct, write-once-respecting updates.
  day1CheckedInAt    DateTime? @map("day1_checked_in_at") @db.Timestamptz(6)
  day2CheckedInAt    DateTime? @map("day2_checked_in_at") @db.Timestamptz(6)
  isWalkIn           Boolean   @default(false) @map("is_walk_in")
  /// pending | provisioning | provisioned | failed — drives the async provision batch.
  provisionStatus    String    @default("pending") @map("provision_status") @db.VarChar(16)
  /// AdminUser.id when an admin digitised a paper entry (no FK by design).
  signedInByAdmin    String?   @map("signed_in_by_admin") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  registration CcwRoadshowRegistration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  student      LmsUser?                 @relation("SignInStudent", fields: [studentId], references: [id], onDelete: SetNull)
  enrollment   LmsEnrollment?           @relation("SignInEnrollment", fields: [enrollmentId], references: [id], onDelete: SetNull)

  @@unique([eventSlug, normalizedEmail])
  @@unique([enrollmentId])
  @@index([eventSlug, normalizedBusiness])
  @@index([eventSlug, normalizedName])
  @@map("ccw_roadshow_sign_ins")
}

/// Margot public assistant — conversation threads (anonymous or linked to a learner).
model MargotConversation {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  sourceIp   String?  @map("source_ip") @db.VarChar(64)
  pagePath   String?  @map("page_path") @db.VarChar(512)
  courseSlug String?  @map("course_slug") @db.VarChar(200)
  lessonId   String?  @map("lesson_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user     LmsUser?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages MargotMessage[]

  @@index([updatedAt(sort: Desc)])
  @@index([userId])
  @@map("margot_conversations")
}

/// Individual turns in a Margot conversation.
model MargotMessage {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           String   @db.VarChar(16)
  content        String   @db.Text
  model          String?  @db.VarChar(120)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation MargotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("margot_messages")
}

/// AI Website — a marketing/enrolment lead captured by the CARSI AI Website front-end.
/// The "employee" that answers, qualifies and remembers every visitor (see docs/ai-website/RUNBOOK.md).
model AiWebsiteLead {
  id             String   @id @db.Uuid
  name           String
  email          String
  phone          String?
  role           String?
  source         String   @default("ai-website") @map("source")
  emailVerified  Boolean  @default(false) @map("email_verified")
  status         String   @default("new") // new | contacted | booked | enrolled | closed
  advisorPathway String?  @map("advisor_pathway") // discipline the advisor mapped, if any
  meta           Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  events AiWebsiteEvent[]

  @@index([email])
  @@index([status, createdAt])
  @@map("ai_website_leads")
}

/// AI Website — an automation event fired on a lead (the n8n-style enrolment flow steps).
/// The notifier writes one row per step; a real email/SMS provider is plugged in behind the
/// notifier interface (src/lib/ai-website/notifier.ts) — off by default, logged here regardless.
model AiWebsiteEvent {
  id        String   @id @db.Uuid
  leadId    String   @map("lead_id") @db.Uuid
  kind      String // lead_captured | email_verified | welcome_email | sms_followup | followup_email | callback_booked
  channel   String? // email | sms | system
  detail    String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  lead AiWebsiteLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@map("ai_website_events")
}
