// LMS tables originally seeded from the one-time WordPress migration (committed exports in data/wordpress-export + SQL loaders). Run `pnpm prisma:pull` when your DB is up to sync with production.
// When your Postgres is running, run `pnpm prisma:pull` (or `npx prisma db pull`) to replace this with an exact introspection of your database.
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model LmsRole {
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String?

  userRoles LmsUserRole[]

  @@map("lms_roles")
}

model LmsUser {
  id                String   @id @db.Uuid
  email             String   @unique
  hashedPassword    String   @map("hashed_password")
  fullName          String?  @map("full_name")
  isActive          Boolean  @default(true) @map("is_active")
  isVerified        Boolean  @default(false) @map("is_verified")
  themePreference   String?  @map("theme_preference")
  /// Present in some deployments (`scripts/seed_production.py`); omit in queries if unused.
  role              String?
  iicrcMemberNumber   String?   @map("iicrc_member_number")
  iicrcExpiryDate     DateTime? @map("iicrc_expiry_date") @db.Date
  iicrcCardImageUrl   String?   @map("iicrc_card_image_url") @db.Text
  iicrcCertifications Json?     @map("iicrc_certifications")
  /// First-run dashboard onboarding (industry, disciplines, goals). Set when wizard completes.
  onboardingCompletedAt DateTime? @map("onboarding_completed_at") @db.Timestamptz(6)
  /// JSON: industry, role, iicrc_experience, disciplines_held[], primary_goal, etc.
  onboarding            Json?
  /// none | email | sms — preference for unfinished-lesson reminders (delivery not yet wired for sms).
  resumeReminderOptIn   String?   @map("resume_reminder_opt_in")
  /// Marketing-style email opt-out (Australian Spam Act). When true, the monthly toolbox-talk drip
  /// email is suppressed. In-app notifications and compliance (recert) emails are NOT affected.
  emailOptOut           Boolean   @default(false) @map("email_opt_out")
  /// When true, `leaderboardDisplayName` may appear on the monthly leaderboard; otherwise an anonymous label is shown.
  leaderboardShowDisplayName Boolean @default(false) @map("leaderboard_show_display_name")
  /// Optional public label for the monthly leaderboard only (never auto-filled from legal name).
  leaderboardDisplayName     String? @map("leaderboard_display_name") @db.VarChar(48)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  userRoles          LmsUserRole[]
  enrollments        LmsEnrollment[] @relation("EnrollmentStudent")
  coursesInstructing LmsCourse[]     @relation("CourseInstructor")
  userDiscounts      UserDiscount[]
  teamMemberships    LmsTeamMember[]
  ownedTeams         LmsTeam[]       @relation("TeamOwner")
  quizAttempts       LmsQuizAttempt[]
  iicrcCecSubmissions LmsIicrcCecSubmission[]
  lessonProgress     LmsLessonProgress[]
  notifications      LmsNotification[]
  courseReviews      LmsCourseReview[] @relation("ReviewStudent")
  reviewReplies      LmsCourseReview[] @relation("ReviewReplyAuthor")
  subscription       LmsSubscription?

  @@map("lms_users")
}

/// In-app (and optionally emailable) notifications: toolbox-talk drip, recert reminders, system.
/// Idempotent on `dedupe_key` (type + subject + period + user) so crons can re-run safely.
model LmsNotification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  /// 'toolbox_talk' | 'recert_due' | 'system' | …
  type      String
  title     String
  body      String    @db.Text
  linkUrl   String?   @map("link_url") @db.Text
  /// Idempotency key — a unique upsert target so the same notification is never created twice.
  dedupeKey String    @unique @map("dedupe_key")
  readAt    DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user LmsUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("lms_notifications")
}

/// Junction table: `ON CONFLICT DO NOTHING` on (user_id, role_id) in loaders.
model LmsUserRole {
  userId String @map("user_id") @db.Uuid
  roleId Int    @map("role_id")

  user LmsUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role LmsRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("lms_user_roles")
}

model LmsCourse {
  id               String   @id @db.Uuid
  slug             String   @unique
  title            String
  description      String?  @db.Text
  shortDescription String?  @map("short_description") @db.Text
  thumbnailUrl     String?  @map("thumbnail_url")
  instructorId     String   @map("instructor_id") @db.Uuid
  status           String
  priceAud         Decimal  @map("price_aud") @db.Decimal(12, 2)
  isFree           Boolean  @default(false) @map("is_free")
  durationHours    Float?   @map("duration_hours")
  level            String?
  category         String?
  tags             Json?
  iicrcDiscipline  String?  @map("iicrc_discipline")
  cecHours         Float?   @map("cec_hours")
  meta             Json?
  isPublished      Boolean? @map("is_published")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  instructor       LmsUser                  @relation("CourseInstructor", fields: [instructorId], references: [id])
  modules          LmsModule[]
  enrollments      LmsEnrollment[]
  userDiscounts    UserDiscount[]
  pathwayCourses   LmsLearningPathwayCourse[]
  quizzes          LmsQuiz[]
  iicrcCecSubmissions LmsIicrcCecSubmission[]
  reviews          LmsCourseReview[]

  @@map("lms_courses")
}

/// Student course reviews / star ratings (1–5). One review per student per course
/// (`uq_lms_course_review`), gated on an existing enrolment. `isPublished` lets an
/// admin hide a review without deleting it; public listings filter on it.
model LmsCourseReview {
  id          String    @id @default(uuid()) @db.Uuid
  courseId    String    @map("course_id") @db.Uuid
  studentId   String    @map("student_id") @db.Uuid
  rating      Int
  title       String?   @db.Text
  body        String?   @db.Text
  isPublished Boolean   @default(true) @map("is_published")
  /// Public instructor/admin response to the review (GP-118).
  reply       String?   @db.Text
  repliedAt   DateTime? @map("replied_at") @db.Timestamptz(6)
  repliedById String?   @map("replied_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  course    LmsCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   LmsUser   @relation("ReviewStudent", fields: [studentId], references: [id], onDelete: Cascade)
  repliedBy LmsUser?  @relation("ReviewReplyAuthor", fields: [repliedById], references: [id], onDelete: SetNull)

  @@unique([courseId, studentId], map: "uq_lms_course_review")
  @@index([courseId, isPublished], map: "ix_lms_course_review_course_published")
  @@map("lms_course_reviews")
}

enum DiscountType {
  percentage
  flat
  free
  custom
}

/// Per-user, per-course pricing overrides managed in admin (`/admin/discounts`).
model UserDiscount {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  courseId       String       @map("course_id") @db.Uuid
  discountType   DiscountType @map("discount_type")
  /// Percentage (0–100), flat AUD off, custom AUD price; null when `free`.
  discountValue  Decimal?     @map("discount_value") @db.Decimal(12, 2)
  expiryDate     DateTime?    @map("expiry_date") @db.Timestamptz(6)
  note           String?      @db.Text
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  user   LmsUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course LmsCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId, courseId])
  @@map("user_discounts")
}

model LmsModule {
  id         String   @id @db.Uuid
  courseId   String   @map("course_id") @db.Uuid
  title      String
  orderIndex Int      @map("order_index")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  course  LmsCourse  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons LmsLesson[]

  @@map("lms_modules")
}

model LmsLesson {
  id          String   @id @db.Uuid
  moduleId    String   @map("module_id") @db.Uuid
  title       String
  contentType String   @map("content_type")
  contentBody String?  @map("content_body") @db.Text
  orderIndex  Int      @map("order_index")
  isPreview   Boolean  @default(false) @map("is_preview")
  resources   Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  module          LmsModule           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progressRecords LmsLessonProgress[]

  @@map("lms_lessons")
}

model LmsLessonProgress {
  id             String    @id @default(uuid()) @db.Uuid
  studentId      String    @map("student_id") @db.Uuid
  lessonId       String    @map("lesson_id") @db.Uuid
  completed      Boolean   @default(false)
  completedAt    DateTime? @map("completed_at") @db.Timestamptz(6)
  lastAccessedAt DateTime  @default(now()) @map("last_accessed_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  lesson  LmsLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student LmsUser   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId], map: "uq_lms_lesson_progress_student_lesson")
  @@map("lms_lesson_progress")
}

/// Unique enrollment per student/course: constraint `uq_lms_enrollment` in migration loaders.
model LmsEnrollment {
  id                   String    @id @db.Uuid
  studentId            String    @map("student_id") @db.Uuid
  courseId             String    @map("course_id") @db.Uuid
  status               String
  paymentReference     String?   @map("payment_reference")
  enrolledAt           DateTime  @default(now()) @map("enrolled_at") @db.Timestamptz(6)
  lastAccessedLessonId String?   @map("last_accessed_lesson_id") @db.Uuid
  completedAt          DateTime? @map("completed_at") @db.Timestamptz(6)
  certificateIssuedAt  DateTime? @map("certificate_issued_at") @db.Timestamptz(6)

  student LmsUser   @relation("EnrollmentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  course  LmsCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  iicrcCecSubmission LmsIicrcCecSubmission?

  @@unique([studentId, courseId], map: "uq_lms_enrollment")
  @@map("lms_enrollments")
}

/// Auto-submitted IICRC CEC certificate emails (renewals@iicrcnet.org) on course completion.
model LmsIicrcCecSubmission {
  id                    String    @id @default(uuid()) @db.Uuid
  enrollmentId          String    @unique @map("enrollment_id") @db.Uuid
  studentId             String    @map("student_id") @db.Uuid
  courseId              String    @map("course_id") @db.Uuid
  recipientEmail        String    @map("recipient_email") @db.VarChar(320)
  technicianEmail       String    @map("technician_email") @db.VarChar(320)
  /// Delivery status: pending | sent | failed | skipped
  status                String    @default("pending") @db.VarChar(16)
  /// Workflow status: pending | sent | awaiting_response | approved | rejected | completed | skipped | failed
  renewalStatus         String    @default("pending") @map("renewal_status") @db.VarChar(24)
  initiatedByAdminEmail String?   @map("initiated_by_admin_email") @db.VarChar(320)
  cecHours              Float?    @map("cec_hours")
  iicrcDiscipline       String?   @map("iicrc_discipline") @db.VarChar(16)
  iicrcMemberNumber     String?   @map("iicrc_member_number") @db.VarChar(32)
  emailSubject          String?   @map("email_subject") @db.Text
  emailTextBody         String?   @map("email_text_body") @db.Text
  emailHtmlBody         String?   @map("email_html_body") @db.Text
  ccEmails              String?   @map("cc_emails") @db.Text
  providerMessageId     String?   @map("provider_message_id") @db.VarChar(128)
  failureReason         String?   @map("failure_reason") @db.Text
  sentAt                DateTime? @map("sent_at") @db.Timestamptz(6)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  enrollment     LmsEnrollment                 @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  student        LmsUser                       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course         LmsCourse                     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  communications LmsIicrcCecCommunication[]
  notes          LmsIicrcCecSubmissionNote[]

  @@index([studentId])
  @@index([status])
  @@index([renewalStatus])
  @@index([sentAt])
  @@map("lms_iicrc_cec_submissions")
}

/// Individual email in the renewal communication audit trail (outbound or inbound).
model LmsIicrcCecCommunication {
  id                    String    @id @default(uuid()) @db.Uuid
  submissionId          String    @map("submission_id") @db.Uuid
  enrollmentId          String    @map("enrollment_id") @db.Uuid
  studentId             String    @map("student_id") @db.Uuid
  courseId              String    @map("course_id") @db.Uuid
  /// outbound | inbound
  direction             String    @db.VarChar(12)
  /// iicrc_submission | technician_receipt | inbound_reply | admin_manual
  kind                  String    @db.VarChar(24)
  initiatedByAdminEmail String?   @map("initiated_by_admin_email") @db.VarChar(320)
  fromEmail             String    @map("from_email") @db.VarChar(320)
  toEmails              String    @map("to_emails") @db.Text
  ccEmails              String?   @map("cc_emails") @db.Text
  subject               String    @db.Text
  textBody              String?   @map("text_body") @db.Text
  htmlBody              String?   @map("html_body") @db.Text
  /// pending | sent | delivered | failed | bounced | skipped
  deliveryStatus        String    @default("pending") @map("delivery_status") @db.VarChar(16)
  providerMessageId     String?   @map("provider_message_id") @db.VarChar(128)
  failureReason         String?   @map("failure_reason") @db.Text
  sentAt                DateTime? @map("sent_at") @db.Timestamptz(6)
  receivedAt            DateTime? @map("received_at") @db.Timestamptz(6)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  submission  LmsIicrcCecSubmission              @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  attachments LmsIicrcCecCommunicationAttachment[]

  @@index([submissionId])
  @@index([studentId])
  @@index([enrollmentId])
  @@index([createdAt])
  @@map("lms_iicrc_cec_communications")
}

model LmsIicrcCecCommunicationAttachment {
  id              String @id @default(uuid()) @db.Uuid
  communicationId String @map("communication_id") @db.Uuid
  filename        String @db.VarChar(255)
  mimeType        String @map("mime_type") @db.VarChar(128)
  sizeBytes       Int?   @map("size_bytes")
  /// outbound | inbound
  direction       String @db.VarChar(12)

  communication LmsIicrcCecCommunication @relation(fields: [communicationId], references: [id], onDelete: Cascade)

  @@index([communicationId])
  @@map("lms_iicrc_cec_communication_attachments")
}

/// Internal admin notes and follow-up actions for a renewal submission.
model LmsIicrcCecSubmissionNote {
  id              String    @id @default(uuid()) @db.Uuid
  submissionId    String    @map("submission_id") @db.Uuid
  authorAdminEmail String   @map("author_admin_email") @db.VarChar(320)
  body            String    @db.Text
  followUpAction  String?   @map("follow_up_action") @db.Text
  followUpDueAt   DateTime? @map("follow_up_due_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  submission LmsIicrcCecSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("lms_iicrc_cec_submission_notes")
}

model LmsCategory {
  id          String  @id @db.Uuid
  slug        String  @unique
  name        String
  description String? @db.Text
  parentId    String? @map("parent_id") @db.Uuid
  orderIndex  Int?    @map("order_index")

  @@map("lms_categories")
}

model LmsLearningPathway {
  id                  String   @id @db.Uuid
  slug                String   @unique
  title               String
  description         String?  @db.Text
  iicrcDiscipline     String?  @map("iicrc_discipline")
  targetCertification String?  @map("target_certification") @db.Text
  estimatedHours      Float?   @map("estimated_hours")
  isPublished         Boolean  @default(false) @map("is_published")
  orderIndex          Int      @default(0) @map("order_index")

  courses LmsLearningPathwayCourse[]

  @@map("lms_learning_pathways")
}

model LmsLearningPathwayCourse {
  pathwayId  String @map("pathway_id") @db.Uuid
  courseId   String @map("course_id") @db.Uuid
  orderIndex Int    @default(0) @map("order_index")

  pathway LmsLearningPathway @relation(fields: [pathwayId], references: [id], onDelete: Cascade)
  course  LmsCourse            @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([pathwayId, courseId])
  @@map("lms_learning_pathway_courses")
}

/// Course quiz (Phase 2) — linked from lessons with content_type `quiz`.
model LmsQuiz {
  id               String   @id @default(uuid()) @db.Uuid
  courseId         String   @map("course_id") @db.Uuid
  title            String
  passPercentage   Int      @default(70) @map("pass_percentage")
  timeLimitMinutes Int?     @map("time_limit_minutes")
  attemptsAllowed  Int      @default(3) @map("attempts_allowed")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  course    LmsCourse         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions LmsQuizQuestion[]
  attempts  LmsQuizAttempt[]

  @@index([courseId])
  @@map("lms_quizzes")
}

model LmsQuizQuestion {
  id            String @id @default(uuid()) @db.Uuid
  quizId        String @map("quiz_id") @db.Uuid
  questionText  String @map("question_text") @db.Text
  options       Json
  correctIndex  Int    @map("correct_index")
  orderIndex    Int    @default(0) @map("order_index")
  points        Int    @default(1)

  quiz LmsQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@map("lms_quiz_questions")
}

model LmsQuizAttempt {
  id          String   @id @default(uuid()) @db.Uuid
  quizId      String   @map("quiz_id") @db.Uuid
  studentId   String   @map("student_id") @db.Uuid
  scorePercent Int     @map("score_percent")
  passed      Boolean
  answers     Json
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  quiz    LmsQuiz  @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student LmsUser  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([quizId, studentId])
  @@map("lms_quiz_attempts")
}

/// B2B team (Phase 2) — seat-based bundles.
model LmsTeam {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  slug         String   @unique
  ownerId      String   @map("owner_id") @db.Uuid
  bundleTier   String   @map("bundle_tier") @db.VarChar(32)
  courseSlug   String?  @map("course_slug") @db.VarChar(128)
  seatLimit    Int      @default(5) @map("seat_limit")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner            LmsUser                @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members          LmsTeamMember[]
  invites          LmsTeamInvite[]
  coursePurchases  LmsTeamCoursePurchase[]

  @@map("lms_teams")
}

/// Seats purchased for a specific course on a team (one row per team checkout).
model LmsTeamCoursePurchase {
  id                String   @id @default(uuid()) @db.Uuid
  teamId            String   @map("team_id") @db.Uuid
  courseSlug        String   @map("course_slug") @db.VarChar(128)
  seatLimit         Int      @map("seat_limit")
  paymentReference  String?  @map("payment_reference") @db.VarChar(255)
  purchasedAt       DateTime @default(now()) @map("purchased_at") @db.Timestamptz(6)

  team LmsTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([courseSlug])
  @@map("lms_team_course_purchases")
}

model LmsTeamMember {
  teamId   String   @map("team_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  role     String   @default("member") @db.VarChar(16)
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz(6)

  team LmsTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user LmsUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@map("lms_team_members")
}

model LmsTeamInvite {
  id        String    @id @default(uuid()) @db.Uuid
  teamId    String    @map("team_id") @db.Uuid
  email     String    @db.VarChar(320)
  role      String    @default("member") @db.VarChar(16)
  token     String    @unique
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  acceptedAt DateTime? @map("accepted_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  team LmsTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([email])
  @@map("lms_team_invites")
}

/// RA-3027 — replaces the single ADMIN_EMAIL+ADMIN_PASSWORD env-var gate
/// for the CARSI admin surface. Multiple admins, per-admin password hash
/// (bcryptjs), per-admin role, audit-able lastLoginAt.
///
/// Migration semantics: backwards-compatible — the env-var login path
/// remains active until at least one row exists in this table. See
/// `docs/ADMIN_AUTH_MIGRATION.md` for rollout steps.
/// Public contact form (`/contact`) — Phase 1 inbox.
model ContactSubmission {
  id        String   @id @default(uuid()) @db.Uuid
  firstName String   @map("first_name") @db.VarChar(120)
  lastName  String   @map("last_name") @db.VarChar(120)
  email     String   @db.VarChar(320)
  message   String   @db.Text
  status    String   @default("new") @db.VarChar(32)
  sourceIp  String?  @map("source_ip") @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  replyDrafts ContactReplyDraft[]

  @@index([status, createdAt(sort: Desc)])
  @@index([email])
  @@map("contact_submissions")
}

/// IICRC-grounded contact replies (Phase 2). An AI draft (or a human's inline
/// reply) plus the provenance/audit record for every outbound. A `pending_approval`
/// draft that cleared the deterministic gates (no-verbatim + judge) is auto-sent
/// once the 2h SLA elapses with no human reply (founder-authorized 2026-07-01).
/// See docs/specs/2026-07-01-carsi-assistant-and-contact-reply.md §14a.
model ContactReplyDraft {
  id               String    @id @default(uuid()) @db.Uuid
  submissionId     String?   @map("submission_id") @db.Uuid
  recipientEmail   String    @map("recipient_email") @db.VarChar(320)
  recipientName    String    @map("recipient_name") @db.VarChar(240)
  question         String    @db.Text
  replyBody        String    @map("reply_body") @db.Text
  standardsCited   String[]  @map("standards_cited")
  stormSources     Json      @map("storm_sources")
  judgeVerdict     Json?     @map("judge_verdict")
  /// Always "pass" — a draft that fails the >= 8-gram guard is never persisted.
  ngramCheck       String    @default("pass") @map("ngram_check") @db.VarChar(16)
  /// Cleared judge + no-verbatim gates → eligible for 2h auto-send.
  autoSendEligible Boolean   @default(false) @map("auto_send_eligible")
  /// "agent:<skill>" for an AI draft, "admin:<email>" for an inline human reply.
  draftedBy        String    @map("drafted_by") @db.VarChar(160)
  /// Human email who approved, or "auto:sla-2h" when the SLA fired. Null while pending.
  approvedBy       String?   @map("approved_by") @db.VarChar(320)
  /// "human" | "auto" — how the send was triggered.
  sentVia          String?   @map("sent_via") @db.VarChar(16)
  /// "pending_approval" | "sent" | "discarded".
  status           String    @default("pending_approval") @db.VarChar(32)
  sentAt           DateTime? @map("sent_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  submission ContactSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([submissionId])
  @@map("contact_reply_drafts")
}

/// Outbound CRM/webhook events (Phase 3) — contact, enrollment, etc.
model CrmEventLog {
  id             String   @id @default(uuid()) @db.Uuid
  eventType      String   @map("event_type") @db.VarChar(64)
  payload        Json
  status         String   @default("pending") @db.VarChar(32)
  responseStatus Int?     @map("response_status")
  responseBody   String?  @map("response_body") @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([eventType, createdAt(sort: Desc)])
  @@index([status])
  @@map("crm_event_logs")
}

/// Stripe webhook idempotency guard. Stripe delivers webhooks at least once,
/// so handlers must claim event IDs before side effects and skip replays.
model StripeWebhookEvent {
  id          String    @id
  type        String    @db.VarChar(128)
  processedAt DateTime? @map("processed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("stripe_webhook_events")
}

/// WS1-E1 (GP-441): individual annual membership (`pro_annual`, A$795/yr).
/// One row per learner; mirrors the Stripe subscription lifecycle. The
/// `getEntitlements` service reads `status` + `currentPeriodEnd` to decide new-
/// enrolment access (active / 7-day past-due grace / lapsed). Additive table —
/// no existing one-off purchase flow depends on it.
model LmsSubscription {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @unique @map("user_id") @db.Uuid
  stripeCustomerId     String?   @map("stripe_customer_id") @db.VarChar(255)
  /// Unique when present so a replayed webhook cannot create a second row.
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id") @db.VarChar(255)
  /// Stripe subscription status: active | trialing | past_due | canceled | unpaid | incomplete | incomplete_expired.
  status               String    @db.VarChar(32)
  /// Plan identifier for UI (currently always `pro_annual`).
  plan                 String    @default("pro_annual") @map("plan") @db.VarChar(32)
  currentPeriodEnd     DateTime? @map("current_period_end") @db.Timestamptz(6)
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  /// Stripe event.created of the snapshot that last set `status`. Out-of-order
  /// guard: a snapshot is applied only when its event timestamp is >= this.
  /// NULL = no ordered write yet (always overwritable; pre-migration rows).
  statusEventAt        DateTime? @map("status_event_at") @db.Timestamptz(6)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user LmsUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId], map: "idx_lms_subscriptions_customer")
  @@map("lms_subscriptions")
}

model AdminUser {
  id             String    @id @default(uuid()) @db.Uuid
  email          String    @unique
  passwordHash   String    @map("password_hash")
  role           String    @default("admin")
  isActive       Boolean   @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at") @db.Timestamptz(6)
  lastLoginIp    String?   @map("last_login_ip")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("admin_users")
}

model CcwRoadshowRegistration {
  id                String   @id @default(uuid()) @db.Uuid
  eventSlug         String   @map("event_slug") @db.VarChar(32)
  freeEntryToken    String   @unique @map("free_entry_token")
  companyName       String?  @map("company_name")
  contactEmail      String   @map("contact_email")
  contactPhone      String?  @map("contact_phone")
  ccwCustomerStatus String?  @map("ccw_customer_status") @db.VarChar(40)
  seatCount         Int      @map("seat_count")
  status            String   @default("confirmed") @db.VarChar(20)
  calendarSynced    Boolean  @default(false) @map("calendar_synced")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  attendees CcwRoadshowAttendee[]

  @@index([eventSlug, status])
  @@index([eventSlug, createdAt(sort: Asc)])
  @@map("ccw_roadshow_registrations")
}

model CcwRoadshowAttendee {
  id              String   @id @default(uuid()) @db.Uuid
  registrationId  String   @map("registration_id") @db.Uuid
  fullName        String   @map("full_name")
  yearsExperience String   @map("years_experience") @db.VarChar(16)
  goals           String   @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  registration CcwRoadshowRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@map("ccw_roadshow_attendees")
}
