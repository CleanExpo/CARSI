# =============================================================================
# DEVELOPMENT ENVIRONMENT - Safe for local use
# =============================================================================
# This file is committed to git as a template. Copy to .env for local use.
# NEVER put real API keys in this file.
# =============================================================================

NODE_ENV=development
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Database (Local Docker)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://starter_user:local_dev_password@localhost:5432/starter_db
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=dev-only-secret-key-not-for-production
JWT_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# AI Provider (Local Ollama - No API costs)
# -----------------------------------------------------------------------------
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Cloud AI keys - MUST remain empty in development
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# External Services (All mocked/disabled in development)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_mock_key_for_development
STRIPE_WEBHOOK_SECRET=whsec_mock_webhook_secret
ELEVENLABS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# API URLs (Local)
# -----------------------------------------------------------------------------
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Development Flags
# -----------------------------------------------------------------------------
MOCK_EXTERNAL_APIS=true
ALLOW_EXTERNAL_CALLS=false
DEBUG_MODE=true
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Safety Flags (DO NOT CHANGE)
# -----------------------------------------------------------------------------
PRODUCTION_LOCK=true
REQUIRE_TEST_PASS_FOR_DEPLOY=true
