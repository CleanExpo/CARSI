# =============================================================================
# PRODUCTION ENVIRONMENT - TEMPLATE ONLY
# =============================================================================
# DO NOT fill in values here. This is a reference template.
# Production values are set in your hosting platform's environment variables.
# =============================================================================

NODE_ENV=production
ENVIRONMENT=production

# Database - Set in hosting platform
DATABASE_URL=

# Authentication - Generate strong secret
JWT_SECRET_KEY=
JWT_EXPIRE_MINUTES=30

# AI Provider
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# External Services
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
ELEVENLABS_API_KEY=

# API URLs - Your production domains
BACKEND_URL=https://api.yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# Production Flags
MOCK_EXTERNAL_APIS=false
ALLOW_EXTERNAL_CALLS=true
DEBUG_MODE=false
LOG_LEVEL=warn

# Safety Flags
PRODUCTION_LOCK=false
REQUIRE_TEST_PASS_FOR_DEPLOY=true
