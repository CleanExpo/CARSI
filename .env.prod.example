# =============================================================================
# CARSI LMS — Production Environment Variables
# Copy to .env.prod and fill in real values before deploying
# =============================================================================

# PostgreSQL
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# Backend
DATABASE_URL=postgresql://carsi_user:${POSTGRES_PASSWORD}@postgres:5432/carsi_prod
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_EXPIRE_MINUTES=60
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
CORS_ORIGINS=["https://carsi.com.au","https://www.carsi.com.au"]

# Frontend
NEXT_PUBLIC_BACKEND_URL=https://carsi.com.au/api
NEXT_PUBLIC_FRONTEND_URL=https://carsi.com.au

# Email (production SMTP)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=noreply@carsi.com.au
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=noreply@carsi.com.au

# Stripe
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME

# Google Drive
GOOGLE_DRIVE_CREDENTIALS_JSON=CHANGE_ME
GOOGLE_DRIVE_ROOT_FOLDER_ID=CHANGE_ME
