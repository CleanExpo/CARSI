    "db:seed-specialty-drying-txt": "npx tsx scripts/seed-specialty-drying-txt.ts",
    "db:seed-contents-specialty-drying-courses-txt": "npx tsx scripts/seed-contents-specialty-drying-courses-txt.ts",
    "db:seed-specialty-courses-resources-txt": "npx tsx scripts/seed-specialty-courses-resources-txt.ts",
    "db:seed-technology-inspection-tools-txt": "npx tsx scripts/seed-technology-inspection-tools-txt.ts",
    "db:seed-odour-smoke-psychro-drying-docx": "npx tsx scripts/seed-odour-smoke-psychro-drying-docx.ts",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test:stripe-webhook": "node scripts/test-stripe-webhook-idempotency.mjs",
    "db:seed-phase2": "npx tsx scripts/seed-phase2-pathways-quizzes.ts",
    "db:seed-floor-care-quizzes": "npx tsx scripts/seed-floor-care-quizzes.ts",
    "db:seed-h5-bird-flu-quiz": "npx tsx scripts/seed-h5-bird-flu-quiz.ts",
    "db:seed-assessment-draft": "npx tsx scripts/seed-assessment-draft.ts",
    "db:seed-floor-care-course": "npx tsx scripts/seed-courses-catalog.ts --slug=floor-care-onboarding-operational-readiness",
    "db:gate-onboarding-off-free": "npx tsx scripts/gate-onboarding-course-off-free.ts",
    "test:a11y": "playwright test tests/accessibility",
    "test:e2e": "playwright test e2e",
    "test:smoke": "playwright test e2e/smoke.spec.ts",
    "test:unit": "vitest run",
    "voice:plan": "npx tsx scripts/generate-course-voiceover.ts --plan",
    "voice:generate": "npx tsx scripts/generate-course-voiceover.ts --generate",
    "video:brand:plan": "npx tsx scripts/automate-brand-videos.ts --plan",
    "video:brand:submit": "npx tsx scripts/automate-brand-videos.ts --submit",
    "video:brand:poll": "npx tsx scripts/automate-brand-videos.ts --poll",
    "video:brand:generate": "npx tsx scripts/automate-brand-videos.ts --execute",
    "video:lessons:plan": "npx tsx scripts/generate-course-lesson-videos.ts --plan",
    "video:lessons:generate": "npx tsx scripts/generate-course-lesson-videos.ts --generate",
    "video:demo:plan": "npx tsx scripts/generate-demo-videos.ts --plan",
    "video:demo:record": "npx tsx scripts/generate-demo-videos.ts --record",
    "video:demo:composite": "npx tsx scripts/generate-demo-videos.ts --composite",
    "video:demo:upload": "npx tsx scripts/generate-demo-videos.ts --upload",
    "video:demo:generate": "npx tsx scripts/generate-demo-videos.ts --execute",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:set-user-password": "npx tsx --tsconfig tsconfig.json scripts/ensure-lms-user-password.ts",
    "db:list-low-module-courses": "npx tsx scripts/list-courses-under-module-count.ts",
    "db:analyze-module-mismatch": "npx tsx scripts/analyze-module-title-mismatch.ts",
    "db:sync-specialty-modules": "npx tsx scripts/sync-specialty-modules-from-collection-txt.ts",
    "db:seed-specialty-collection-txt": "npx tsx scripts/seed-carsi-specialty-courses-collection-txt.ts",
    "db:strip-ai-vendor-refs": "npx tsx scripts/strip-ai-vendor-references-from-lms.ts",
    "ccw:scrape:plan": "npx tsx scripts/scrape-ccw-products.ts --plan",
    "ccw:scrape": "npx tsx scripts/scrape-ccw-products.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/eslintrc": "^3.3.3",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@playwright/test": "^1.49.1",
    "@surma/rollup-plugin-off-main-thread": "^2.2.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "16.2.9",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "7.8.0",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@hono/node-server": "1.19.14",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shell-quote": "1.8.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
